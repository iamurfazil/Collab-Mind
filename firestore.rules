rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // -----------------------------------------------------------------------
    // SECURE BACKEND-ONLY ARCHITECTURE
    // -----------------------------------------------------------------------
    // The Collab-Mind application uses a Node.js backend with the 
    // firebase-admin SDK to handle all database operations. 
    // Since the admin SDK automatically bypasses these security rules, 
    // we strictly deny all direct client-side reads and writes. 
    // This prevents malicious actors from using the public Firebase 
    // configuration to access the database directly.
    // -----------------------------------------------------------------------
    
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
